 	public void followPatheasy(List<Node> path) {
		if(path != null) {
			if(path.size() > 0) {
				Vector2i target = path.get(path.size() - 1).tile;
			    if(x < target.x * 16 ) {
			    	x+=.speed;
			    	.down = false;
			    	.up = false;
			    	.right = true;
			    	.left = false;
			    }else if(x > target.x * 16 ) {
			    	x-=.speed;
			    	.down = false;
			    	.up = false;
			    	.right = false;
			    	.left = true;
			    }
			    if(y < target.y * 16) {
			    	y+=.speed;
			    	.down = true;
			    	.up = false;
			    	.right = false;
			    	.left = false;
			    }else if(y > target.y * 16) {
			    	y-=.speed;
			    	.down = false;
			    	.up = true;
			    	.right = false;
			    	.left = false;
			    }
			    
			    if(x == target.x * 16 && y == target.y * 16) {
			    	path.remove(path.size() - 1);
			    }
			}
		}
	}
 
 
 
 
 
 
 
 
 
 
 
 
 
 